{
  // Cloudflare Workers Static Assets config for TacticalCraft.
  // `wrangler deploy` finds this Workers config (name + assets), so it
  // skips the Pages workspace-detection path that was failing.
  // Serves the Vite build output in dist/ as a static site / SPA.
  "name": "tacticalcraft",
  "compatibility_date": "2024-11-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
